<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Configure cloud backups -->
    <cloud-backup>
        <!-- Exclude authentication state and secure stores from cloud sync -->
        <exclude domain="sharedpref" path="vend.auth.v1.xml" />
        <exclude domain="database" path="rk_SecureStore" />
        <exclude domain="sharedpref" path="SecureStore.xml" />
    </cloud-backup>
    
    <!-- Configure local transfers (device-to-device migration) -->
    <device-transfer>
        <!-- Exclude credentials to force re-authentication on new device -->
        <exclude domain="sharedpref" path="vend.auth.v1.xml" />
        <exclude domain="database" path="rk_SecureStore" />
        <exclude domain="sharedpref" path="SecureStore.xml" />
    </device-transfer>
</data-extraction-rules>
