{
  "cli": {
    "version": ">= 8.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "buildType": "simulator"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "buildType": "archive"
      },
      "env": {
        "NODE_ENV": "staging"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "credentialsSource": "remote",
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease"
      },
      "ios": {
        "buildType": "archive"
      },
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}",
        "appleSpecificPassword": "${APPLE_SPECIFIC_PASSWORD}"
      },
      "android": {
        "serviceAccount": "${GOOGLE_SERVICE_ACCOUNT}",
        "track": "production"
      }
    },
    "preview": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}",
        "appleSpecificPassword": "${APPLE_SPECIFIC_PASSWORD}"
      },
      "android": {
        "serviceAccount": "${GOOGLE_SERVICE_ACCOUNT}",
        "track": "internal"
      }
    }
  }
}
